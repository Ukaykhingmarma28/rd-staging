[mysqld]
# ── InnoDB — use ~68% of DB container RAM (1.5GB * 0.68 ≈ 1024MB) ──
innodb_buffer_pool_size        = 1024M
innodb_log_file_size           = 128M
innodb_log_buffer_size         = 32M
innodb_flush_log_at_trx_commit = 2      # slight perf boost (safe for WooCommerce)
innodb_read_io_threads         = 2
innodb_write_io_threads        = 2

# ── Connections ──────────────────────────────────────────────────
max_connections                = 100
thread_cache_size              = 10
table_open_cache               = 2000

# ── Query cache (disabled in MariaDB 10.1.7+ by default, keep off)
query_cache_type               = 0
query_cache_size               = 0

# ── Temp tables ──────────────────────────────────────────────────
tmp_table_size                 = 64M
max_heap_table_size            = 64M

# ── Slow query log ───────────────────────────────────────────────
slow_query_log                 = 1
slow_query_log_file            = /var/lib/mysql/slow.log
long_query_time                = 1

# ── Character set ────────────────────────────────────────────────
character_set_server           = utf8mb4
collation_server               = utf8mb4_unicode_ci

# ── I/O and buffer tuning ──────────────────────────────────────
innodb_io_capacity             = 500
innodb_io_capacity_max         = 1000
join_buffer_size               = 2M
sort_buffer_size               = 2M
read_rnd_buffer_size           = 1M
